generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  image         String?
  emailVerified DateTime?
  role          String    @default("TEACHER") // TEACHER, ADMIN, SUPER_ADMIN
  isApproved    Boolean   @default(false)
  isPremium     Boolean   @default(false)
  credits       Int       @default(3)
  papers        Paper[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Paper {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolName     String
  subject        String
  examName       String
  totalMarks     Int
  date           DateTime
  layoutSettings Json?
  timeLimit         Int?                // Strict test time limit in minutes
  status            String              @default("DRAFT") // DRAFT, PENDING_ADMIN, PENDING_SUPERADMIN, APPROVED, REJECTED
  isPublishedOnline Boolean             @default(false)
  questions         Question[]
  submissions       StudentSubmission[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model StudentSubmission {
  id          String   @id @default(cuid())
  paperId     String
  paper       Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  studentName String
  rollNo      String?
  division    String?
  responses   Json     // Stores map of { questionId: answer_value }
  totalScore  Float?
  aiFeedback    Json?    // Caches Gemini explanations and suggested marks
  cheatWarnings Int      @default(0) // Tracks tab switches and blurs
  submittedAt   DateTime @default(now())
}

model Question {
  id            String   @id @default(cuid())
  paperId       String
  paper         Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  type          String // MCQ, TF, DESCRIPTIVE, MATCH, MAP, FILL_IN_THE_BLANKS
  content       Json
  marks         Int
  sequenceOrder Int
  customHeading String?
  hasOr         Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
